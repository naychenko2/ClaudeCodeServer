<?xml version="1.0" encoding="utf-8"?>
<!-- Источники пакетов проекта: только nuget.org. <clear/> отсекает машинные фиды
     (например, корпоративные Azure DevOps), чтобы сборка не зависела от их доступности. -->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
