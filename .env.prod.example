# Образец прод-окружения для контейнера naychenko.me.
# Скопируй в .env.prod (он в .gitignore) и впиши свои значения.
# Запуск прода:
#   docker compose --env-file .env.prod -f docker-compose.claude.yml -f docker-compose.claude.prod.yml up -d --build

# Имя compose-проекта → префикс volume (claude-prod_claude-data / claude-prod_claude-home).
# Разводит прод-контур с dev (claudecodeserver_*). Не менять без миграции данных.
COMPOSE_PROJECT_NAME=claude-prod

# Папка проектов прода на хосте, пробрасывается в /projects
CLAUDE_PROJECTS_DIR=C:/ClaudeHome

# Папка с TLS-сертами: fullchain.pem + privkey.pem
CLAUDE_CERTS_DIR=C:/certs/naychenko

# HTTP(S)-прокси для выхода контейнера в интернет (сборка И runtime).
# Пусто = прямой интернет. Резолв внешних хостов делает сам прокси (CONNECT).
CLAUDE_EGRESS_PROXY=http://192.168.7.208:2080

# Platform API-ключ fal.ai (формат key:secret) для учёта стоимости генераций.
FAL_API_KEY=

# Опц.: фиксированный API-ключ приложения, чтобы не зависеть от генерации в data/auth-key.txt.
# Раскомментировать, если на ключ завязаны внешние интеграции.
# Auth__ApiKey=cck_...
