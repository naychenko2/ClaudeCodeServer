# URL self-hosted Dify без trailing slash
DIFY_API_URL=http://your-dify-host/v1

# Knowledge Base API key (Settings → API Keys → Knowledge Base API key)
# Формат: dataset-xxxxxxxxxxxxxxxxxxxxxxxx
DIFY_API_KEY=dataset-xxxxxxxxxxxxxxxxxxxxxxxx

# ID датасета по умолчанию (опционально)
# Если задан — можно не указывать dataset_id в большинстве инструментов
DIFY_DEFAULT_DATASET_ID=
