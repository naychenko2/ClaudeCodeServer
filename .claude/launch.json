{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "dotnet",
      "runtimeArgs": ["run", "--project", "backend/ClaudeHomeServer"],
      "port": 5000
    },
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "frontend"],
      "port": 5173
    },
    {
      "name": "smoke-frontend",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "cd frontend && npx vite --config vite.config.smoke.ts"],
      "port": 5199
    }
  ]
}
