# Образец локальных значений для docker compose (claude-контейнер).
# Скопируй в .env (он в .gitignore) и впиши свои. Compose читает .env автоматически.

# Папка проектов на хосте, пробрасывается в /projects
CLAUDE_PROJECTS_DIR=C:/ClaudeProjects

# HTTP(S)-прокси для выхода контейнера в интернет (сборка И runtime).
# Пусто = прямой интернет без прокси. Резолв внешних хостов делает сам прокси (CONNECT).
CLAUDE_EGRESS_PROXY=http://192.168.7.208:2080

# Папка с TLS-сертами (только прод-оверрайд): fullchain.pem + privkey.pem
CLAUDE_CERTS_DIR=C:/certs/naychenko
