{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": ["http://localhost:5173"]
  },
  "DefaultProjectsPath": "/projects",
  "Sandbox": {
    "#comment": "Общая docker-песочница пользователей со средой container. ProjectsRoot — хостовый корень их проектов (монтируется в /projects целиком); пусто = песочница выключена, container-пользователи не смогут работать. Машинно-специфичное — в appsettings.Local.json.",
    "Image": "claude-sandbox:latest",
    "ContainerName": "cc-sandbox",
    "ProjectsRoot": "",
    "McpApiUrl": "http://host.docker.internal:5000",
    "PortRangeStart": 42000,
    "PortRangeSize": 20,
    "McpRoot": "/app/mcp",
    "DockerPath": "docker",
    "Proxy": "",
    "Memory": "",
    "Cpus": ""
  },
  "Dify": {
    "ApiUrl": "http://localhost:8080/v1",
    "ApiKey": "",
    "IndexingTechnique": "high_quality",
    "Namespace": "",
    "ForeignNamespaces": []
  },
  "McpConfigPath": "",
  "LlmProviders": {

  "ClaudeSubscriptions": {
    "#comment": "Дополнительные подписки Claude. Ключ — произвольный (my-second, work-account). Значение DisplayName — для логов. OAuthToken — токен от claude setup-token на аккаунте второй подписки. Несколько подписок = балансировка + failover при exhausted."
  },
    "deepseek": {
      "DisplayName": "DeepSeek",
      "AnthropicBaseUrl": "https://api.deepseek.com/anthropic",
      "ApiBaseUrl": "https://api.deepseek.com",
      "ApiKey": "",
      "SmallModel": "deepseek-v4-flash",
      "Balance": "deepseek",
      "QueryModelsApi": true,
      "SupportsImages": false,
      "Models": [
        {
          "Id": "deepseek-v4-flash",
          "DisplayName": "DeepSeek Flash",
          "Description": "Быстрая и недорогая · рутинные задачи и большой объём",
          "ContextWindow": 1000000,
          "PriceInMissPer1M": 0.14,
          "PriceInHitPer1M": 0.0028,
          "PriceOutPer1M": 0.28
        },
        {
          "Id": "deepseek-v4-pro",
          "DisplayName": "DeepSeek Pro",
          "Description": "Глубокое рассуждение · сложные задачи и код",
          "ContextWindow": 1000000,
          "PriceInMissPer1M": 0.435,
          "PriceInHitPer1M": 0.003625,
          "PriceOutPer1M": 0.87
        }
      ]
    },
    "glm": {
      "DisplayName": "GLM",
      "AnthropicBaseUrl": "https://api.z.ai/api/anthropic",
      "ApiBaseUrl": "https://api.z.ai/api/paas/v4",
      "ApiKey": "",
      "SmallModel": "glm-4.7",
      "QueryModelsApi": true,
      "ExtraEnv": { "API_TIMEOUT_MS": "3000000" },
      "Models": [
        {
          "Id": "glm-5.2",
          "DisplayName": "GLM 5.2",
          "Description": "Агентное кодирование · баланс скорости и качества",
          "ContextWindow": 200000
        },
        {
          "Id": "glm-5.2[1m]",
          "DisplayName": "GLM 5.2 (1M)",
          "Description": "То же с окном 1M · большие кодовые базы и документы",
          "ContextWindow": 1000000
        }
      ]
    }
  },
  "Claude": {
    "DisallowedTools": [
      "mcp__claude_ai_Google_Calendar__*",
      "mcp__claude_ai_Google_Drive__*",
      "mcp__claude_ai_Gamma__*",
      "mcp__claude_ai_Miro__*",
      "mcp__claude_ai_Todoist__*"
    ]
  },
  "WebDav": {
    "NtlmMapWindowsNames": false
  },
  "Changelog": {
    "Model": "haiku",
    "DefaultDays": 30,
    "TimeoutMs": 480000,
    "AuthorAliases": {
      "depeche81@msn.com": "Григорий",
      "andrey@naychenko.ru": "Андрей",
      "anaychenko@ya.ru": "Андрей"
    }
  },
  "OnlyOffice": {
    "ServerUrl": "http://localhost:8090",
    "BackendUrl": "http://host.docker.internal:5000",
    "DownloadToken": "",
    "AllowedCallbackHosts": ["localhost", "host.docker.internal", "onlyoffice-ds"]
  },
  "ReverseProxy": {
    "Routes": {
      "oo-web-apps":      { "ClusterId": "onlyoffice", "Match": { "Path": "/web-apps/{**catch-all}" } },
      "oo-sdkjs":         { "ClusterId": "onlyoffice", "Match": { "Path": "/sdkjs/{**catch-all}" } },
      "oo-fonts":         { "ClusterId": "onlyoffice", "Match": { "Path": "/fonts/{**catch-all}" } },
      "oo-dictionaries":  { "ClusterId": "onlyoffice", "Match": { "Path": "/dictionaries/{**catch-all}" } },
      "oo-sdkjs-plugins": { "ClusterId": "onlyoffice", "Match": { "Path": "/sdkjs-plugins/{**catch-all}" } },
      "oo-doceditor":     { "ClusterId": "onlyoffice", "Match": { "Path": "/doceditor/{**catch-all}" } },
      "oo-doc":           { "ClusterId": "onlyoffice", "Match": { "Path": "/doc/{**catch-all}" } },
      "oo-coauthoring":   { "ClusterId": "onlyoffice", "Match": { "Path": "/coauthoring/{**catch-all}" } },
      "oo-cache":         { "ClusterId": "onlyoffice", "Match": { "Path": "/cache/{**catch-all}" } },
      "drawio":           { "ClusterId": "drawio",     "Match": { "Path": "/drawio/{**catch-all}" } }
    },
    "Clusters": {
      "onlyoffice": {
        "Destinations": {
          "default": { "Address": "http://localhost:8090" }
        }
      },
      "drawio": {
        "Destinations": {
          "default": { "Address": "http://localhost:8091" }
        }
      }
    }
  }
}
