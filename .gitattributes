# Скрипты, засеваемые в Linux-контейнер как есть: CRLF в них ломает вызов
# workflow по имени (строгая валидация CLI «script contains control characters»)
claude-defaults/workflows/*.js text eol=lf
mcp/**/*.js text eol=lf
# Обвязка запуска процессов в sandbox-контейнере: CRLF в shebang ломает /bin/sh
backend/sandbox/*.sh text eol=lf
