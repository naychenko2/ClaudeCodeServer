{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": ["http://localhost:5173"]
  },
  "DefaultProjectsPath": "/projects",
  "Dify": {
    "ApiUrl": "http://localhost:8080/v1",
    "ApiKey": "",
    "IndexingTechnique": "high_quality"
  },
  "McpConfigPath": "",
  "DeepSeek": {
    "ApiKey": "",
    "BaseUrl": "https://api.deepseek.com",
    "MaxToolIterations": 15,
    "MaxTokens": 8192,
    "EnableShellTool": true,
    "ShellTimeoutSeconds": 120,
    "Models": [
      {
        "Id": "deepseek-v4-flash",
        "DisplayName": "DeepSeek Flash",
        "ContextWindow": 1000000,
        "Thinking": false,
        "PriceInMissPer1M": 0.14,
        "PriceInHitPer1M": 0.0028,
        "PriceOutPer1M": 0.28
      },
      {
        "Id": "deepseek-v4-flash-thinking",
        "ApiModel": "deepseek-v4-flash",
        "DisplayName": "DeepSeek Flash Thinking",
        "ContextWindow": 1000000,
        "Thinking": true,
        "PriceInMissPer1M": 0.14,
        "PriceInHitPer1M": 0.0028,
        "PriceOutPer1M": 0.28
      },
      {
        "Id": "deepseek-v4-pro",
        "DisplayName": "DeepSeek Pro",
        "ContextWindow": 1000000,
        "Thinking": true,
        "PriceInMissPer1M": 0.435,
        "PriceInHitPer1M": 0.003625,
        "PriceOutPer1M": 0.87
      }
    ]
  },
  "Claude": {
    "DisallowedTools": [
      "mcp__claude_ai_Google_Calendar__*",
      "mcp__claude_ai_Google_Drive__*",
      "mcp__claude_ai_Gamma__*",
      "mcp__claude_ai_Miro__*",
      "mcp__claude_ai_Todoist__*"
    ]
  },
  "WebDav": {
    "NtlmMapWindowsNames": false
  },
  "Changelog": {
    "Model": "haiku",
    "DefaultDays": 30,
    "AuthorAliases": {
      "depeche81@msn.com": "Григорий",
      "andrey@naychenko.ru": "Андрей",
      "anaychenko@ya.ru": "Андрей"
    }
  },
  "OnlyOffice": {
    "ServerUrl": "http://localhost:8090",
    "BackendUrl": "http://host.docker.internal:5000",
    "DownloadToken": "",
    "AllowedCallbackHosts": ["localhost", "host.docker.internal", "onlyoffice-ds"]
  },
  "ReverseProxy": {
    "Routes": {
      "oo-web-apps":      { "ClusterId": "onlyoffice", "Match": { "Path": "/web-apps/{**catch-all}" } },
      "oo-sdkjs":         { "ClusterId": "onlyoffice", "Match": { "Path": "/sdkjs/{**catch-all}" } },
      "oo-fonts":         { "ClusterId": "onlyoffice", "Match": { "Path": "/fonts/{**catch-all}" } },
      "oo-dictionaries":  { "ClusterId": "onlyoffice", "Match": { "Path": "/dictionaries/{**catch-all}" } },
      "oo-sdkjs-plugins": { "ClusterId": "onlyoffice", "Match": { "Path": "/sdkjs-plugins/{**catch-all}" } },
      "oo-doceditor":     { "ClusterId": "onlyoffice", "Match": { "Path": "/doceditor/{**catch-all}" } },
      "oo-doc":           { "ClusterId": "onlyoffice", "Match": { "Path": "/doc/{**catch-all}" } },
      "oo-coauthoring":   { "ClusterId": "onlyoffice", "Match": { "Path": "/coauthoring/{**catch-all}" } },
      "oo-cache":         { "ClusterId": "onlyoffice", "Match": { "Path": "/cache/{**catch-all}" } }
    },
    "Clusters": {
      "onlyoffice": {
        "Destinations": {
          "default": { "Address": "http://localhost:8090" }
        }
      }
    }
  }
}
